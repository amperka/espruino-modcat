{
  "name": "modcat",
  "type": "module",
  "version": "0.0.1",
  "description": "",
  "scripts": {
    "verify": "yarn eslint && yarn prettify",
    "eslint": "eslint modules",
    "prettify": "prettylint modules/**/*.js",
    "minify": "find modules -type f -name '*.js' \\! -name '*.min.js' -exec sh -c 'uglifyjs -c -m -o \"${1%.js}.min.js\" \"$1\"' sh {} \\;",
    "build": "yarn minify"
  },
  "author": "Amperka LLC",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "prettier": "^3.8.1",
    "prettylint": "^2.0.0",
    "uglify-js": "^3.19.3"
  }
}
